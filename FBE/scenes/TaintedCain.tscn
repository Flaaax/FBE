[sub_resource type="Shader" id="Shader_8eo3w"]
code = "shader_type canvas_item;

group_uniforms Colors;
uniform vec4 deep_color : source_color = vec4(0.025, 0.035, 0.10, 1.0);
uniform vec4 nebula_color : source_color = vec4(0.18, 0.04, 0.42, 1.0);
uniform vec4 energy_color : source_color = vec4(0.05, 0.75, 1.0, 1.0);
uniform vec4 hot_color : source_color = vec4(1.0, 0.28, 0.78, 1.0);

group_uniforms Motion;
uniform float speed : hint_range(0.0, 4.0, 0.01) = 0.75;
uniform float warp_strength : hint_range(0.0, 2.0, 0.01) = 0.65;
uniform float star_intensity : hint_range(0.0, 3.0, 0.01) = 1.15;

const float TAU2 = 6.28318530718;

float hash(vec2 p) {
	p = fract(p * vec2(123.34, 456.21));
	p += dot(p, p + 45.32);
	return fract(p.x * p.y);
}

float noise(vec2 p) {
	vec2 i = floor(p);
	vec2 f = fract(p);
	vec2 u = f * f * (3.0 - 2.0 * f);

	float a = hash(i);
	float b = hash(i + vec2(1.0, 0.0));
	float c = hash(i + vec2(0.0, 1.0));
	float d = hash(i + vec2(1.0, 1.0));

	return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
}

float fbm(vec2 p) {
	float v = 0.0;
	float a = 0.5;
	mat2 r = mat2(vec2(0.80, -0.60), vec2(0.60, 0.80));

	for (int i = 0; i < 5; i++) {
		v += a * noise(p);
		p = r * p * 2.05 + 13.7;
		a *= 0.5;
	}

	return v;
}

float star_layer(vec2 p, float t) {
	vec2 cell = floor(p);
	vec2 local = fract(p) - 0.5;

	float rnd = hash(cell);
	vec2 offset = vec2(hash(cell + 17.1), hash(cell + 91.7)) - 0.5;
	float d = length(local - offset);

	float rare = step(0.985, rnd);
	float twinkle = 0.55 + 0.45 * sin(t * 6.0 + rnd * TAU2);
	float star = 1.0 - smoothstep(0.0, 0.035, d);

	return star * rare * twinkle;
}

void fragment() {
	vec2 uv = UV;
	vec2 p = uv * 2.0 - 1.0;

	float aspect = SCREEN_PIXEL_SIZE.y / SCREEN_PIXEL_SIZE.x;
	p.x *= aspect;

	float t = TIME * speed;

	float r = length(p);
	float a = atan(p.y, p.x);

	vec2 warped = p;
	warped.x += sin(p.y * 3.0 + t * 0.9) * 0.04 * warp_strength;
	warped.y += cos(p.x * 4.0 - t * 0.7) * 0.04 * warp_strength;

	float wr = length(warped);
	float wa = atan(warped.y, warped.x);

	float tunnel_depth = 1.0 / max(wr, 0.08);
	vec2 tunnel_uv = vec2(wa / TAU2 + t * 0.045, tunnel_depth * 0.075 - t * 0.18);

	float nebula = fbm(tunnel_uv * 4.0 + vec2(sin(t * 0.25), cos(t * 0.19)));
	float cloud = fbm(warped * 2.7 + vec2(t * 0.13, -t * 0.08));

	vec3 rgb = mix(deep_color.rgb, nebula_color.rgb, nebula);
	rgb = mix(rgb, hot_color.rgb, smoothstep(0.58, 1.0, cloud) * 0.55);

	float core = exp(-r * 3.2);
	float pulse = 0.65 + 0.35 * sin(t * 2.4);
	rgb += energy_color.rgb * core * pulse * 0.95;

	float stars = 0.0;
	stars += star_layer(p * 115.0 + vec2(-t * 8.0, t * 2.5), t);
	stars += star_layer(p * 185.0 + vec2(t * 4.5, -t * 7.0) + 43.0, t) * 0.65;
	stars += star_layer(p * 70.0 + vec2(-t * 2.0, -t * 3.0) + 100.0, t) * 0.85;

	float star_mask = smoothstep(0.18, 1.15, r);
	rgb += vec3(0.8, 0.95, 1.0) * stars * star_mask * star_intensity;

	float scan = sin((uv.y + t * 0.08) * 850.0) * 0.012;
	rgb += scan;

	float vignette = 1.0 - smoothstep(0.55, 1.75, r) * 0.72;
	rgb *= vignette;

	COLOR = vec4(rgb, 1.0);
}
"

